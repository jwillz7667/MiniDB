{
  "name": "minidb",
  "version": "2.0.0",
  "description": "A durable, zero-native-dependency SQL database engine in TypeScript: B+Tree storage, write-ahead log + ARIES-lite crash recovery, a Volcano executor with JOINs and aggregates, prepared statements, an in-memory backend, and a Kysely dialect.",
  "type": "module",
  "license": "MIT",
  "author": "jwillz7667",
  "repository": {
    "type": "git",
    "url": "https://github.com/jwillz7667/MiniDB.git"
  },
  "keywords": [
    "database",
    "sql",
    "sqlite",
    "embedded",
    "b-tree",
    "wal",
    "crash-recovery",
    "in-memory",
    "kysely",
    "typescript",
    "pure-js",
    "no-native"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./kysely": {
      "types": "./dist/kysely/index.d.ts",
      "import": "./dist/kysely/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "bin": {
    "minidb": "./dist/repl.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "repl": "tsx src/repl.ts",
    "bench": "tsx src/bench/bench.ts",
    "bench:vs-sqlite": "tsx scripts/bench-vs-sqlite.ts",
    "example": "tsx examples/quickstart.ts",
    "demo:pool": "tsx scripts/demo-pool.ts",
    "demo:crash": "tsx scripts/demo-crash.ts",
    "demo:explain": "tsx scripts/demo-explain.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "kysely": "^0.29.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "kysely": "^0.27 || ^0.28 || ^0.29"
  },
  "peerDependenciesMeta": {
    "kysely": {
      "optional": true
    }
  }
}
